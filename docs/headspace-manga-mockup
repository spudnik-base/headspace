<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0A0A0A">
<title>HeadSpace · Manga IB Edition</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
/* ── MANGA VARIABLES ── */
:root {
  --ink: #0A0A0A;
  --paper: #F2EBD9;
  --paper2: #EAE0CA;
  --panel: #FAF6EE;
  --red: #C8001A;
  --red-dim: rgba(200,0,26,0.08);
  --yellow: #F5C800;
  --yellow-dim: rgba(245,200,0,0.12);
  --blue-ink: #001F5B;
  --white: #FEFCF8;
  --gutter: 6px;
  --b3: 3px solid var(--ink);
  --b4: 4px solid var(--ink);
  --b2: 2px solid var(--ink);
  --font-bang: 'Bangers', cursive;
  --font-body: 'Outfit', sans-serif;
  --dots-sm: radial-gradient(circle, rgba(10,10,10,0.18) 1px, transparent 1px) 0 0 / 6px 6px;
  --dots-lg: radial-gradient(circle, rgba(10,10,10,0.12) 1.5px, transparent 1.5px) 0 0 / 10px 10px;
  --dots-red: radial-gradient(circle, rgba(200,0,26,0.22) 1px, transparent 1px) 0 0 / 7px 7px;
  --dots-yel: radial-gradient(circle, rgba(245,200,0,0.35) 1.5px, transparent 1.5px) 0 0 / 8px 8px;
}

*{ box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { width: 100%; height: 100%; overflow: hidden; background: var(--ink); font-family: var(--font-body); }

/* ── ROTATE OVERLAY ── */
#rotate-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 9999;
  background: var(--paper);
  background-image: var(--dots-lg);
  flex-direction: column; align-items: center; justify-content: center;
  gap: 20px;
  border: var(--b4);
}
@media screen and (orientation: portrait) and (max-width: 1024px) {
  #rotate-overlay { display: flex; }
}
.rotate-icon { animation: spin90 2s ease-in-out infinite; }
@keyframes spin90 {
  0%,40%{ transform: rotate(0deg); }
  60%,100%{ transform: rotate(90deg); }
}
.rotate-title {
  font-family: var(--font-bang); font-size: 42px; letter-spacing: 3px;
  color: var(--ink); text-align: center; line-height: 1;
}
.rotate-sub { font-size: 14px; color: var(--ink); opacity: 0.6; text-align: center; max-width: 220px; font-weight: 600; }
.rotate-title span { color: var(--red); }

/* ── SCREENS ── */
.screen { display: none; position: absolute; inset: 0; width: 100%; height: 100%; }
.screen.active { display: flex; }

/* ── SCREEN: HOME ── */
#screen-home {
  background: var(--paper);
  border: var(--b4);
}
.home-left {
  width: 260px; min-width: 220px;
  border-right: var(--b4);
  background: var(--ink);
  display: flex; flex-direction: column;
  padding: 28px 24px 24px;
  position: relative; overflow: hidden;
}
.home-left-dots {
  position: absolute; inset: 0;
  background: var(--dots-lg);
  opacity: 0.3; pointer-events: none;
}
.home-logo {
  font-family: var(--font-bang); font-size: 52px; letter-spacing: 4px;
  color: var(--white); line-height: 0.95; margin-bottom: 4px; position: relative; z-index: 1;
}
.home-logo span { color: var(--yellow); }
.home-edition {
  border: 2px solid var(--yellow); display: inline-block;
  padding: 3px 10px; font-size: 11px; font-weight: 800; letter-spacing: 2px;
  text-transform: uppercase; color: var(--yellow); margin-bottom: 20px; position: relative; z-index: 1;
}
.home-speech {
  background: var(--white); border: var(--b3); border-radius: 14px;
  padding: 14px 16px; position: relative; z-index: 1; margin-bottom: auto;
}
.home-speech::after {
  content: ''; position: absolute; bottom: -14px; left: 24px;
  border: 7px solid transparent; border-top-color: var(--ink);
}
.home-speech::before {
  content: ''; position: absolute; bottom: -10px; left: 24px;
  border: 7px solid transparent; border-top-color: var(--white); z-index: 1;
}
.speech-title { font-family: var(--font-bang); font-size: 18px; letter-spacing: 1px; color: var(--ink); margin-bottom: 4px; }
.speech-body { font-size: 12px; color: var(--ink); opacity: 0.7; line-height: 1.5; font-weight: 500; }
.home-teacher-btn {
  display: flex; align-items: center; gap: 8px;
  background: none; border: 2px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.6); padding: 10px 14px; border-radius: 8px;
  font-family: var(--font-body); font-size: 13px; font-weight: 600; cursor: pointer;
  transition: all 0.15s; position: relative; z-index: 1; margin-top: 16px; width: 100%; text-align: left;
}
.home-teacher-btn:hover { border-color: var(--yellow); color: var(--yellow); }

.home-right {
  flex: 1; display: flex; flex-direction: column;
  padding: 20px 24px 20px;
}
.home-right-header {
  font-family: var(--font-bang); font-size: 13px; letter-spacing: 3px;
  color: var(--ink); opacity: 0.45; margin-bottom: 14px; text-transform: uppercase;
}
.subject-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gutter); flex: 1;
}
.subject-card {
  background: var(--panel); border: var(--b3);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 6px; cursor: pointer; padding: 12px 6px; position: relative;
  transition: transform 0.1s; user-select: none;
}
.subject-card:active { transform: scale(0.97); }
.subject-card.selected {
  background: var(--yellow);
  box-shadow: 4px 4px 0 var(--ink);
  transform: translate(-2px, -2px);
}
.subject-card.selected .subj-name { color: var(--ink); }
.subj-icon { width: 38px; height: 38px; }
.subj-name { font-family: var(--font-bang); font-size: 14px; letter-spacing: 1px; color: var(--ink); text-align: center; line-height: 1.1; }
.subj-count { font-size: 10px; color: var(--ink); opacity: 0.5; font-weight: 700; }
.home-start-row { display: flex; justify-content: flex-end; margin-top: 14px; }
.btn-manga {
  font-family: var(--font-bang); font-size: 22px; letter-spacing: 3px;
  background: var(--ink); color: var(--yellow); border: none;
  padding: 12px 32px; cursor: pointer;
  box-shadow: 4px 4px 0 var(--red);
  transition: transform 0.1s, box-shadow 0.1s;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.btn-manga:hover { box-shadow: 6px 6px 0 var(--red); transform: translate(-2px,-2px); }
.btn-manga:active { box-shadow: 2px 2px 0 var(--red); transform: translate(2px,2px); }

/* ── SCREEN: SETUP ── */
#screen-setup {
  background: var(--paper);
  border: var(--b4);
}
.setup-left {
  width: 55%; border-right: var(--b4);
  padding: 24px 28px;
  display: flex; flex-direction: column; overflow: hidden;
}
.setup-subject-badge {
  display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
}
.setup-subj-icon { width: 44px; height: 44px; }
.setup-subj-name { font-family: var(--font-bang); font-size: 40px; letter-spacing: 3px; color: var(--ink); line-height: 1; }
.setup-section { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: var(--ink); opacity: 0.4; margin-bottom: 10px; }
.topic-chips { display: flex; flex-wrap: wrap; gap: 7px; overflow-y: auto; }
.topic-chip {
  background: var(--panel); border: var(--b2);
  padding: 6px 14px; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: all 0.12s; user-select: none;
}
.topic-chip:hover { background: var(--paper2); }
.topic-chip.selected {
  background: var(--ink); color: var(--white);
  box-shadow: 2px 2px 0 var(--red);
}

.setup-right {
  flex: 1; padding: 24px 28px;
  display: flex; flex-direction: column;
}
.timer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: auto; }
.timer-opt {
  background: var(--panel); border: var(--b2);
  padding: 16px 12px; text-align: center; cursor: pointer; transition: all 0.12s;
}
.timer-opt:hover { background: var(--paper2); }
.timer-opt.selected {
  background: var(--yellow); border: var(--b3);
  box-shadow: 3px 3px 0 var(--ink);
  transform: translate(-1px,-1px);
}
.timer-val { font-family: var(--font-bang); font-size: 36px; letter-spacing: 2px; display: block; line-height: 1; color: var(--ink); }
.timer-unit { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--ink); opacity: 0.55; }
.setup-back-btn { background: none; border: var(--b2); padding: 8px 16px; font-family: var(--font-bang); font-size: 16px; letter-spacing: 1px; cursor: pointer; margin-bottom: 16px; width: fit-content; }
.setup-back-btn:hover { background: var(--paper2); }

/* ── SCREEN: GAME ── */
#screen-game {
  flex-direction: column;
  background: var(--paper);
  border: var(--b4);
}
.game-topbar {
  display: flex; align-items: center; gap: 0;
  height: 46px; border-bottom: var(--b3); flex-shrink: 0;
  background: var(--ink);
}
.game-timer-track { flex: 1; height: 100%; background: rgba(255,255,255,0.1); overflow: hidden; position: relative; }
.game-timer-fill {
  position: absolute; left: 0; top: 0; bottom: 0;
  background: var(--yellow); transition: width 1s linear, background-color 0.3s;
}
.game-timer-fill.warn { background: #FF8C00; }
.game-timer-fill.danger { background: var(--red); }
.game-scores {
  display: flex; align-items: center; gap: 0;
  border-left: var(--b3); height: 100%;
}
.game-score-box {
  display: flex; align-items: center; gap: 6px;
  padding: 0 16px; height: 100%; border-right: var(--b3);
  font-family: var(--font-bang); font-size: 20px; letter-spacing: 1px;
}
.game-score-box.correct { color: var(--yellow); }
.game-score-box.passed { color: var(--red); }
.game-countdown {
  font-family: var(--font-bang); font-size: 28px; letter-spacing: 2px;
  color: var(--white); padding: 0 18px; min-width: 72px; text-align: center;
  border-right: var(--b3); height: 100%; display: flex; align-items: center; justify-content: center;
}
.game-countdown.warn { color: #FF8C00; }
.game-countdown.danger { color: var(--red); animation: cdanger 0.5s ease-in-out infinite alternate; }
@keyframes cdanger { from{ opacity:1 } to{ opacity:0.4 } }

.game-body { flex: 1; display: flex; overflow: hidden; }

/* LEFT ZONE */
.game-zone {
  width: 170px; flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 10px; cursor: pointer; border: none; background: none;
  transition: background 0.08s; position: relative; overflow: hidden;
}
.game-zone-left { border-right: var(--b3); background: var(--yellow-dim); }
.game-zone-right { border-left: var(--b3); background: var(--red-dim); }
.game-zone-left:hover { background: rgba(245,200,0,0.22); }
.game-zone-right:hover { background: rgba(200,0,26,0.14); }
.game-zone-left:active { background: rgba(245,200,0,0.4); }
.game-zone-right:active { background: rgba(200,0,26,0.25); }

.zone-dots-y { position: absolute; inset: 0; background: var(--dots-yel); opacity: 0.6; pointer-events: none; }
.zone-dots-r { position: absolute; inset: 0; background: var(--dots-red); opacity: 0.6; pointer-events: none; }

.zone-arrow {
  font-family: var(--font-bang); font-size: 64px; line-height: 1;
  position: relative; z-index: 1;
}
.zone-arrow-up { color: var(--ink); animation: bobbyu 1.6s ease-in-out infinite; }
.zone-arrow-down { color: var(--red); animation: bobbyd 1.6s ease-in-out infinite; }
@keyframes bobbyu { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-7px)} }
@keyframes bobbyd { 0%,100%{transform:translateY(0)} 50%{transform:translateY(7px)} }

.zone-label { font-family: var(--font-bang); font-size: 13px; letter-spacing: 2px; text-align: center; position: relative; z-index: 1; line-height: 1.2; }
.zone-label-top { font-size: 10px; opacity: 0.55; text-transform: uppercase; letter-spacing: 1.5px; }
.zone-label-main { font-size: 22px; letter-spacing: 2px; }
.zone-label-main.yl { color: var(--ink); }
.zone-label-main.rd { color: var(--red); }
.zone-label-sub { font-size: 10px; font-weight: 700; font-family: var(--font-body); opacity: 0.55; }

/* CENTER TERM CARD */
.game-center {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.speed-lines {
  position: absolute; inset: -20px; pointer-events: none; z-index: 0;
}
.term-card-wrap { position: relative; z-index: 2; width: 100%; max-width: 480px; padding: 0 20px; }
.term-card-manga {
  background: var(--white); border: var(--b4);
  padding: 32px 28px; text-align: center;
  box-shadow: 6px 6px 0 var(--ink);
  position: relative;
}
.term-card-manga.flash-c { background: var(--yellow); animation: flashc 0.3s ease; }
.term-card-manga.flash-p { background: rgba(200,0,26,0.08); animation: flashp 0.3s ease; }
@keyframes flashc { 0%{ transform:scale(1.04) } 100%{ transform:scale(1) } }
@keyframes flashp { 0%{ transform:scale(0.97) } 100%{ transform:scale(1) } }
.term-cat-pill {
  display: inline-block; background: var(--ink); color: var(--white);
  font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase;
  padding: 3px 12px; margin-bottom: 16px;
}
.term-word-big {
  font-family: var(--font-bang); font-size: clamp(32px, 5vw, 64px);
  letter-spacing: 3px; color: var(--ink); line-height: 1.05;
}
.term-num { position: absolute; top: 10px; right: 14px; font-family: var(--font-bang); font-size: 13px; color: var(--ink); opacity: 0.3; letter-spacing: 1px; }

/* FX TEXT */
#fx-overlay {
  position: absolute; inset: 0; z-index: 10;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none; opacity: 0;
}
#fx-overlay.show-c { animation: fxshow 0.55s ease forwards; }
#fx-overlay.show-p { animation: fxshow 0.55s ease forwards; }
@keyframes fxshow { 0%{opacity:0;transform:scale(0.6)} 30%{opacity:1;transform:scale(1.05)} 70%{opacity:1;transform:scale(1)} 100%{opacity:0;transform:scale(0.9)} }
.fx-word {
  font-family: var(--font-bang); font-size: 96px; letter-spacing: 6px;
  -webkit-text-stroke: 4px var(--ink);
  text-align: center; line-height: 1; transform: rotate(-8deg);
  filter: drop-shadow(5px 5px 0 rgba(0,0,0,0.3));
}
.fx-word.fx-c { color: var(--yellow); }
.fx-word.fx-p { color: var(--red); }

/* ── SCREEN: COUNTDOWN ── */
#screen-countdown {
  background: var(--ink); align-items: center; justify-content: center;
  flex-direction: column; gap: 16px; border: var(--b4);
  background-image: var(--dots-lg);
}
.cdown-ring {
  width: 200px; height: 200px; border: 5px solid var(--yellow);
  display: flex; align-items: center; justify-content: center; position: relative;
}
.cdown-num {
  font-family: var(--font-bang); font-size: 120px; letter-spacing: 0; color: var(--yellow);
  animation: cpop 0.7s ease;
}
@keyframes cpop { from{transform:scale(2);opacity:0} 60%{transform:scale(0.9)} to{transform:scale(1);opacity:1} }
.cdown-hint { font-family: var(--font-bang); font-size: 20px; letter-spacing: 3px; color: var(--white); opacity: 0.7; text-align: center; max-width: 320px; }
.cdown-mode { font-size: 13px; font-weight: 700; color: var(--yellow); letter-spacing: 1px; }

/* ── SCREEN: SUMMARY ── */
#screen-summary {
  background: var(--paper); border: var(--b4);
}
.summary-left {
  width: 300px; border-right: var(--b4);
  background: var(--ink);
  display: flex; flex-direction: column;
  padding: 28px 24px;
  position: relative; overflow: hidden;
}
.summary-left-dots { position: absolute; inset:0; background:var(--dots-lg); opacity:0.25; pointer-events:none; }
.summary-rank { font-family: var(--font-bang); font-size: 80px; letter-spacing:4px; color: var(--yellow); line-height:0.9; position:relative;z-index:1; }
.summary-rank-sub { font-size:13px; font-weight:700; color:var(--white); opacity:0.6; letter-spacing:2px; text-transform:uppercase; position:relative;z-index:1; margin-bottom:20px; }
.stat-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-bottom:20px; position:relative;z-index:1; }
.stat-cell { background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12); padding:12px 8px; text-align:center; }
.stat-val { font-family:var(--font-bang); font-size:32px; letter-spacing:2px; line-height:1; display:block; }
.stat-lbl { font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:1.5px; opacity:0.5; color:var(--white); }
.stat-cell.c .stat-val { color:var(--yellow); }
.stat-cell.p .stat-val { color:var(--red); }
.stat-cell.pct .stat-val { color:#7BD4FF; }
.summary-play-again { margin-top:auto; position:relative;z-index:1; }

.summary-right {
  flex:1; display:flex; flex-direction:column; overflow:hidden;
}
.summary-tabs {
  display:flex; border-bottom: var(--b3); flex-shrink:0; background: var(--paper2);
}
.sum-tab {
  flex:1; padding:12px; font-family:var(--font-bang); font-size:15px; letter-spacing:1.5px;
  text-align:center; cursor:pointer; border-right: var(--b2); transition:background 0.12s;
  background: none; border-top:none; border-left:none; border-bottom:none;
}
.sum-tab:last-child { border-right:none; }
.sum-tab.active { background:var(--yellow); border-bottom: var(--b3); }
.sum-tab:hover:not(.active) { background:var(--paper); }

.summary-list { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:8px; }
.sum-card {
  background:var(--panel); border: var(--b2); padding:12px 16px;
  border-left:4px solid var(--ink); transition:border-color 0.2s;
}
.sum-card.correct { border-left-color: var(--yellow); }
.sum-card.passed { border-left-color: var(--red); }
.sum-term { font-family:var(--font-bang); font-size:18px; letter-spacing:1px; color:var(--ink); margin-bottom:4px; }
.sum-def { font-size:13px; color:var(--ink); opacity:0.65; line-height:1.55; }
.sum-def.loading { height:13px; background:var(--paper2); animation:shim 1.5s infinite; border-radius:2px; }
.sum-def.loading2 { height:13px; background:var(--paper2); animation:shim 1.5s 0.2s infinite; border-radius:2px; width:75%; margin-top:4px; }
@keyframes shim { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* ── TEACHER SCREEN ── */
#screen-teacher {
  background:var(--paper); border:var(--b4);
  flex-direction:column;
}
.teacher-inner { flex:1; display:flex; gap:0; overflow:hidden; }
.teacher-left {
  width:50%; border-right:var(--b4); padding:24px 28px;
  display:flex; flex-direction:column;
}
.teacher-right { flex:1; padding:24px 28px; display:flex; flex-direction:column; }
.teacher-title { font-family:var(--font-bang); font-size:36px; letter-spacing:3px; color:var(--ink); margin-bottom:6px; }
.teacher-sub { font-size:13px; color:var(--ink); opacity:0.6; font-weight:500; line-height:1.5; margin-bottom:20px; }
.teacher-textarea {
  background:var(--white); border:var(--b3); padding:14px;
  font-family:var(--font-body); font-size:14px; color:var(--ink);
  resize:none; min-height:160px; outline:none; width:100%;
}
.teacher-textarea:focus { border-color:var(--red); }
.teacher-add-btn {
  background:var(--ink); color:var(--white); border:none; padding:10px 20px;
  font-family:var(--font-bang); font-size:18px; letter-spacing:2px; cursor:pointer;
  margin-top:10px; transition:background 0.1s;
}
.teacher-add-btn:hover { background:#333; }
.custom-items { flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:6px; margin-bottom:16px; }
.custom-item {
  display:flex; align-items:center; gap:10px;
  background:var(--panel); border:var(--b2); padding:8px 14px;
  font-size:14px; font-weight:600;
}
.remove-x { background:none; border:none; color:var(--red); font-size:20px; cursor:pointer; line-height:1; margin-left:auto; }
.empty-msg { font-size:13px; color:var(--ink); opacity:0.4; text-align:center; padding:20px 0; font-style:italic; }

/* ── TOP NAV BAR ── */
.screen-topbar {
  display:flex; align-items:center; border-bottom:var(--b3); height:44px; flex-shrink:0;
  background:var(--paper2);
}
.back-btn {
  font-family:var(--font-bang); font-size:16px; letter-spacing:1px; cursor:pointer;
  background:none; border:none; border-right:var(--b3); padding:0 16px; height:100%;
  transition:background 0.1s;
}
.back-btn:hover { background:var(--paper); }
.topbar-title { font-family:var(--font-bang); font-size:18px; letter-spacing:2px; padding-left:14px; color:var(--ink); }

/* ── PERMISSION SCREEN ── */
#screen-permission {
  background:var(--paper); border:var(--b4);
  flex-direction:column; align-items:center; justify-content:center; gap:16px;
  background-image: var(--dots-sm);
}
.perm-icon-wrap { background:var(--white); border:var(--b4); padding:24px; box-shadow:6px 6px 0 var(--ink); }
