  try{
    const c=getACtx(),o=c.createOscillator(),g=c.createGain();
    o.frequency.value=1000;o.type='square';
    o.connect(g);g.connect(c.destination);
    g.gain.setValueAtTime(0.07,c.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,c.currentTime+0.06);
    o.start();o.stop(c.currentTime+0.08);
  }catch(e){}
}

// ══ SCREEN NAV ══
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ══ HOME INIT ══
function initHome(){
  const grid=document.getElementById('subject-grid');
  grid.innerHTML='';
  Object.keys(IB).forEach(name=>{
    const data=IB[name];
    const total=Object.values(data.topics).reduce((a,arr)=>a+arr.length,0);
    const el=document.createElement('div');
    el.className='subject-card'+(S.subject===name?' selected':'');
    el.innerHTML=`<div class="subj-icon">${ICONS[data.icon]}</div><div class="subj-name">${name}</div><div class="subj-count">${total} TERMS</div>`;
    el.onclick=()=>{
      document.querySelectorAll('.subject-card').forEach(c=>c.classList.remove('selected'));
      el.classList.add('selected'); S.subject=name;
    };
    grid.appendChild(el);
  });
}

// ══ SETUP ══
function goToSetup(){
  const data=IB[S.subject];
  document.getElementById('setup-name').textContent=S.subject.toUpperCase();
  document.getElementById('setup-icon').innerHTML=ICONS[data.icon];
  S.topics=Object.keys(data.topics);
  const chips=document.getElementById('topic-chips');
  chips.innerHTML='';
  Object.keys(data.topics).forEach(t=>{
    const chip=document.createElement('div');
    chip.className='topic-chip selected';
    chip.textContent=t;
    chip.onclick=()=>{
      const i=S.topics.indexOf(t);
      if(i>-1){ if(S.topics.length>1){S.topics.splice(i,1);chip.classList.remove('selected');} }
      else{ S.topics.push(t);chip.classList.add('selected'); }
    };
    chips.appendChild(chip);
  });
  showScreen('screen-setup');
}

function selectTimer(sec,el){
  S.duration=sec;
  document.querySelectorAll('.timer-opt').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
}

// ══ TEACHER MODE ══
function addCustomTerms(){
  const inp=document.getElementById('teacher-input');
  inp.value.split('\n').map(l=>l.trim()).filter(Boolean).forEach(t=>{
    if(!S.customTerms.find(x=>x.term===t)) S.customTerms.push({term:t,category:'Custom',subject:'Custom'});
  });
  inp.value=''; renderCustom();
}
function renderCustom(){
  const list=document.getElementById('custom-items');
  document.getElementById('custom-label').textContent=`CUSTOM DECK (${S.customTerms.length})`;
  if(!S.customTerms.length){ list.innerHTML='<div class="empty-msg">No terms added yet — paste your list on the left.</div>'; return; }
  list.innerHTML='';
  S.customTerms.forEach((t,i)=>{
    const el=document.createElement('div');
    el.className='custom-item';
    el.innerHTML=`<span>${t.term}</span><button class="remove-x" onclick="S.customTerms.splice(${i},1);renderCustom()">×</button>`;
    list.appendChild(el);
  });
}
function startCustomGame(){
  if(!S.customTerms.length) return;
  S.deck=shuffle([...S.customTerms]);
  checkTiltPermission();
}

// ══ SPEED LINES (SVG) ══
function drawSpeedLines(){
  const g=document.getElementById('speed-lines-g');
  g.innerHTML='';
  const cx=300,cy=200,n=48;
  for(let i=0;i<n;i++){
    const a=(i/n)*Math.PI*2;
    const start=60+Math.random()*40;
    const end=260+Math.random()*60;
    const x1=cx+Math.cos(a)*start, y1=cy+Math.sin(a)*start;
    const x2=cx+Math.cos(a)*end, y2=cy+Math.sin(a)*end;
    const line=document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1',x1);line.setAttribute('y1',y1);
    line.setAttribute('x2',x2);line.setAttribute('y2',y2);
    line.setAttribute('stroke-width',Math.random()*1.2+0.3);
    g.appendChild(line);
  }
}

// ══ GAME ══
function buildDeck(){
  const data=IB[S.subject]; let terms=[];
  S.topics.forEach(t=>{ data.topics[t].forEach(term=>terms.push({term,category:t,subject:S.subject})); });
  return shuffle(terms);
}
function shuffle(a){ return [...a].sort(()=>Math.random()-0.5); }
function startGame(){ S.deck=buildDeck(); checkTiltPermission(); }
function checkTiltPermission(){
  if(typeof DeviceOrientationEvent!=='undefined' && typeof DeviceOrientationEvent.requestPermission==='function'){
    showScreen('screen-permission');
  } else {
    S.tiltEnabled=!!window.DeviceOrientationEvent;
    beginCountdown();
  }
}
function requestPermission(){
  DeviceOrientationEvent.requestPermission().then(r=>{ S.tiltEnabled=r==='granted'; beginCountdown(); }).catch(()=>{ S.tiltEnabled=false; beginCountdown(); });
}
function startWithoutTilt(){ S.tiltEnabled=false; beginCountdown(); }

function beginCountdown(){
  showScreen('screen-countdown');
  document.getElementById('cdown-mode').textContent=S.tiltEnabled?'TILT CONTROLS ACTIVE':'USING ON-SCREEN ZONES';
  let n=3;
  const el=document.getElementById('cdown-num');
  el.textContent=n;
  const iv=setInterval(()=>{
    n--;
    if(n===0){ clearInterval(iv); el.textContent='GO!'; setTimeout(launchGame,700); }
    else{ el.style.animation='none'; el.offsetHeight; el.style.animation='cpop 0.7s ease'; el.textContent=n; }
  },1000);
}

function launchGame(){
  S.idx=0; S.score={correct:[],passed:[]}; S.timeLeft=S.duration;
  drawSpeedLines();
  showScreen('screen-game');
  renderCard();
  startTimer();
  if(S.tiltEnabled) window.addEventListener('deviceorientation',onTilt);
}

function renderCard(){
  if(S.idx>=S.deck.length){ endGame(); return; }
  const c=S.deck[S.idx];
  document.getElementById('term-word').textContent=c.term;
  document.getElementById('term-cat').textContent=c.category.toUpperCase();
  document.getElementById('term-num').textContent=`${S.idx+1} / ${S.deck.length}`;
}

const FX_C=['NICE!','YES!!','NAILED','BOOM!','ACE!!'];
const FX_P=['SKIP!','PASS!','NEXT!','NOPE!'];

function showFX(correct){
  const el=document.getElementById('fx-overlay');
  const word=document.getElementById('fx-word');
  el.className='';
  word.textContent=correct?FX_C[Math.floor(Math.random()*FX_C.length)]:FX_P[Math.floor(Math.random()*FX_P.length)];
  word.className='fx-word '+(correct?'fx-c':'fx-p');
  void el.offsetWidth;
  el.className=correct?'show-c':'show-p';
}

function registerCorrect(){
  S.score.correct.push(S.deck[S.idx]);
  const card=document.getElementById('term-card');
  card.classList.remove('flash-c','flash-p'); void card.offsetWidth; card.classList.add('flash-c');
  setTimeout(()=>card.classList.remove('flash-c'),350);
  showFX(true); playCorrect();
  if(navigator.vibrate) navigator.vibrate(70);
  document.getElementById('hud-correct').textContent=S.score.correct.length;
  S.idx++; setTimeout(renderCard,250);
}
function registerPass(){
  S.score.passed.push(S.deck[S.idx]);
  const card=document.getElementById('term-card');
  card.classList.remove('flash-c','flash-p'); void card.offsetWidth; card.classList.add('flash-p');
  setTimeout(()=>card.classList.remove('flash-p'),350);
  showFX(false); playPass();
  if(navigator.vibrate) navigator.vibrate([30,40,30]);
  document.getElementById('hud-pass').textContent=S.score.passed.length;
  S.idx++; setTimeout(renderCard,250);
}

function onTilt(e){
  const beta=e.beta, now=Date.now();
  if(now-S.tiltCooldown<1400||beta===null) return;
  if(beta>118){ S.tiltCooldown=now; registerCorrect(); }
  else if(beta<18){ S.tiltCooldown=now; registerPass(); }
}

function startTimer(){
  updateTimerUI();
  S.timerID=setInterval(()=>{
    S.timeLeft--;
    updateTimerUI();
    if(S.timeLeft<=5) playTick();
    if(S.timeLeft<=0) endGame();
  },1000);
}
function updateTimerUI(){
  const pct=(S.timeLeft/S.duration)*100;
  const fill=document.getElementById('timer-fill');
  const timer=document.getElementById('hud-timer');
  fill.style.width=pct+'%';
  timer.textContent=S.timeLeft;
  if(S.timeLeft<=5){ fill.className='game-timer-fill danger'; timer.className='game-countdown danger'; }
  else if(S.timeLeft<=15){ fill.className='game-timer-fill warn'; timer.className='game-countdown warn'; }
  else{ fill.className='game-timer-fill'; timer.className='game-countdown'; }
}

// ══ END & SUMMARY ══
function endGame(){
  clearInterval(S.timerID);
  window.removeEventListener('deviceorientation',onTilt);
  const {correct,passed}=S.score;
  const total=correct.length+passed.length;
  const pct=total>0?Math.round(correct.length/total*100):0;
  document.getElementById('sum-correct').textContent=correct.length;
  document.getElementById('sum-pass').textContent=passed.length;
  document.getElementById('sum-pct').textContent=pct+'%';
  const rank=pct>=90?'S':pct>=75?'A':pct>=60?'B':pct>=40?'C':'D';
  const subs={S:'LEGENDARY',A:'EXCELLENT',B:'SOLID',C:'KEEP AT IT',D:'STUDY UP'};
  document.getElementById('sum-rank').textContent=rank;
  document.getElementById('sum-rank-sub').textContent=subs[rank];
  S.summaryTab='passed';
  renderSummaryTab();
  showScreen('screen-summary');
  if(passed.length||correct.length) fetchDefs();
}

function switchTab(tab,el){
  S.summaryTab=tab;
  document.querySelectorAll('.sum-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  renderSummaryTab();
}

function renderSummaryTab(){
  const list=document.getElementById('summary-list');
  list.innerHTML='';
  const items=S.summaryTab==='passed'?S.score.passed:S.score.correct;
  if(!items.length){ list.innerHTML='<div class="empty-msg">Nothing here yet.</div>'; return; }
  items.forEach(item=>{
    const card=document.createElement('div');
    card.className='sum-card '+(S.summaryTab==='passed'?'passed':'correct');
    card.dataset.term=item.term;
    card.innerHTML=`<div class="sum-term">${item.term}</div><div class="sum-def loading"></div><div class="sum-def loading2"></div>`;
    list.appendChild(card);
  });
}

async function fetchDefs(){
  const allItems=[...S.score.passed,...S.score.correct.slice(0,4)];
  if(!allItems.length) return;
  const termList=allItems.map(i=>`${i.term} (${i.subject})`).join(', ');
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1500,
        messages:[{role:'user',content:`You are an IB examiner. For each term, write one crisp sentence definition (max 25 words) suitable for a 17-year-old IB student. Be precise and exam-relevant. Return ONLY a JSON array, no markdown, no backticks. Format: [{"term":"...","definition":"..."}]. Terms: ${termList}`}]
      })
    });
    const data=await res.json();
    const raw=data.content.map(b=>b.text||'').join('');
    const clean=raw.replace(/```json|```/g,'').trim();
    const defs=JSON.parse(clean);
    defs.forEach(d=>{
      document.querySelectorAll('.sum-card').forEach(card=>{
        const termEl=card.querySelector('.sum-term');
        if(termEl&&termEl.textContent===d.term){
          card.querySelectorAll('.sum-def').forEach(el=>el.remove());
          const def=document.createElement('div');
          def.className='sum-def'; def.textContent=d.definition;
          card.appendChild(def);
        }
      });
    });
  }catch(e){
    document.querySelectorAll('.sum-def').forEach(el=>{
      el.className='sum-def'; el.textContent='Check your notes for this one.';
    });
  }
}

function playAgain(){
  showScreen('screen-home'); S.subject='Biology';
  initHome();
}

